<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- V8 JIT (richiesto da Electron) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Caricamento di native modules non firmati (se un giorno userai better-sqlite3, sharp, ecc.) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Debugger / child process (richiesto per spawn di 'claude' CLI) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Network (fetch RSS, OPML probe) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Leggi/scrivi nel vault utente (Documents) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
